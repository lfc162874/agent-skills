{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TechnicalOutlineGenerationOutput",
  "type": "object",
  "required": [
    "documentTitle",
    "structureStrategy",
    "chapters",
    "coverageMatrix",
    "warnings"
  ],
  "additionalProperties": false,
  "properties": {
    "documentTitle": {
      "type": "string",
      "minLength": 1
    },
    "structureStrategy": {
      "type": "object",
      "required": [
        "type",
        "reason"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "score_driven",
            "total_sub_total",
            "process_driven",
            "module_driven",
            "hybrid",
            "unknown"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "chapters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/chapter"
      }
    },
    "coverageMatrix": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/coverageItem"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "chapter": {
      "type": "object",
      "required": [
        "id",
        "title",
        "expanded",
        "sortNo",
        "basis",
        "evidenceRefs"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "expanded": {
          "type": "boolean"
        },
        "sortNo": {
          "type": "integer",
          "minimum": 1
        },
        "basis": {
          "type": "string"
        },
        "evidenceRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidenceRef"
          }
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/chapter"
          },
          "default": []
        }
      }
    },
    "evidenceRef": {
      "type": "object",
      "required": [
        "type",
        "chunkId",
        "reason"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "scoring",
            "requirement",
            "format",
            "inferred"
          ]
        },
        "chunkId": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "coverageItem": {
      "type": "object",
      "required": [
        "scoringItem",
        "maxScore",
        "coveredBy",
        "coverageStatus",
        "reason"
      ],
      "additionalProperties": false,
      "properties": {
        "scoringItem": {
          "type": "string",
          "minLength": 1
        },
        "maxScore": {
          "type": [
            "number",
            "null"
          ]
        },
        "coveredBy": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "coverageStatus": {
          "type": "string",
          "enum": [
            "covered",
            "partially_covered",
            "not_covered"
          ]
        },
        "reason": {
          "type": "string"
        }
      }
    }
  }
}
