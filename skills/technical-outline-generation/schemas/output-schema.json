{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TechnicalOutlineGenerationOutputCompatible",
  "description": "兼容当前 TechnicalOutlinePromptBuilder.java 的技术卷大纲输出结构。当前生产输出只允许 documentTitle 与 chapters，不包含 structureStrategy、coverageMatrix、warnings、basis、evidenceRefs 等增强字段。",
  "type": "object",
  "required": [
    "documentTitle",
    "chapters"
  ],
  "additionalProperties": false,
  "properties": {
    "documentTitle": {
      "type": "string",
      "minLength": 1
    },
    "chapters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/chapter"
      }
    }
  },
  "$defs": {
    "chapter": {
      "type": "object",
      "required": [
        "id",
        "title",
        "sortNo"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "expanded": {
          "type": "boolean"
        },
        "sortNo": {
          "type": "integer",
          "minimum": 1
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/chapter"
          },
          "default": []
        }
      }
    }
  }
}
