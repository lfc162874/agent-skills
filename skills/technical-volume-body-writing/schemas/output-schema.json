{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "technical-volume-body-writing.output.schema.json",
  "title": "TechnicalVolumeBodyWritingOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sectionId",
    "sectionTitle",
    "blocks",
    "scoreCoverage",
    "evidenceRefs",
    "qualityHints"
  ],
  "properties": {
    "sectionId": {
      "type": "string",
      "description": "当前章节 ID"
    },
    "sectionTitle": {
      "type": "string",
      "description": "当前章节标题"
    },
    "blocks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/paragraphBlock"
          },
          {
            "$ref": "#/$defs/listBlock"
          },
          {
            "$ref": "#/$defs/tableBlock"
          },
          {
            "$ref": "#/$defs/headingBlock"
          }
        ]
      }
    },
    "scoreCoverage": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "itemKey",
          "itemName",
          "covered",
          "coverageDescription"
        ],
        "properties": {
          "itemKey": {
            "type": "string"
          },
          "itemName": {
            "type": "string"
          },
          "covered": {
            "type": "boolean"
          },
          "coverageDescription": {
            "type": "string"
          }
        }
      }
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sourceId",
          "sourceType",
          "usedFor"
        ],
        "properties": {
          "sourceId": {
            "type": "string"
          },
          "sourceType": {
            "type": "string"
          },
          "usedFor": {
            "type": "string"
          }
        }
      }
    },
    "qualityHints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hasMarkdown",
        "hasManualNumbering",
        "hasFakeInfoRisk",
        "hasUnsupportedClaim",
        "outlineViolation"
      ],
      "properties": {
        "hasMarkdown": {
          "type": "boolean"
        },
        "hasManualNumbering": {
          "type": "boolean"
        },
        "hasFakeInfoRisk": {
          "type": "boolean"
        },
        "hasUnsupportedClaim": {
          "type": "boolean"
        },
        "outlineViolation": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "paragraphBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "text",
        "styleKey"
      ],
      "properties": {
        "type": {
          "const": "paragraph"
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "styleKey": {
          "const": "body"
        }
      }
    },
    "listBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "ordered",
        "styleKey",
        "items"
      ],
      "properties": {
        "type": {
          "const": "list"
        },
        "ordered": {
          "type": "boolean"
        },
        "styleKey": {
          "enum": [
            "orderedList",
            "unorderedList"
          ]
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "tableBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "styleKey",
        "columns",
        "rows"
      ],
      "properties": {
        "type": {
          "const": "table"
        },
        "styleKey": {
          "const": "standardTable"
        },
        "columns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "headingBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "level",
        "text",
        "styleKey"
      ],
      "properties": {
        "type": {
          "const": "heading"
        },
        "level": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "styleKey": {
          "enum": [
            "heading1",
            "heading2",
            "heading3"
          ]
        }
      }
    }
  }
}
