{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "technical-volume-body-writing.output.schema.json",
  "title": "TechnicalVolumeBodyWritingOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sectionId",
    "sectionTitle",
    "blocks",
    "scoreCoverage",
    "evidenceRefs",
    "qualityHints"
  ],
  "properties": {
    "sectionId": {
      "type": "string",
      "description": "当前章节 ID"
    },
    "sectionTitle": {
      "type": "string",
      "description": "当前章节标题"
    },
    "blocks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/paragraphBlock"
          },
          {
            "$ref": "#/$defs/listBlock"
          },
          {
            "$ref": "#/$defs/tableBlock"
          },
          {
            "$ref": "#/$defs/headingBlock"
          }
        ]
      }
    },
    "scoreCoverage": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "itemKey",
          "itemName",
          "covered",
          "coverageDescription"
        ],
        "properties": {
          "itemKey": {
            "type": "string"
          },
          "itemName": {
            "type": "string"
          },
          "covered": {
            "type": "boolean"
          },
          "coverageDescription": {
            "$ref": "#/$defs/cleanText"
          }
        }
      }
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "sourceId",
          "sourceType",
          "usedFor"
        ],
        "properties": {
          "sourceId": {
            "type": "string"
          },
          "sourceType": {
            "type": "string"
          },
          "usedFor": {
            "$ref": "#/$defs/cleanText"
          }
        }
      }
    },
    "qualityHints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hasMarkdown",
        "hasManualNumbering",
        "hasFakeInfoRisk",
        "hasUnsupportedClaim",
        "outlineViolation"
      ],
      "properties": {
        "hasMarkdown": {
          "type": "boolean"
        },
        "hasManualNumbering": {
          "type": "boolean"
        },
        "hasFakeInfoRisk": {
          "type": "boolean"
        },
        "hasUnsupportedClaim": {
          "type": "boolean"
        },
        "outlineViolation": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "cleanText": {
      "type": "string",
      "minLength": 1,
      "allOf": [
        {
          "not": {
            "pattern": "^[\\s　\\t]+"
          }
        },
        {
          "not": {
            "pattern": "\\*\\*|```|^\\s{0,3}#{1,6}\\s|^\\s*[-*+]\\s+|^\\s*>\\s+"
          }
        },
        {
          "not": {
            "pattern": "^\\s*(\\d+(\\.\\d+)*[\\.、]?\\s+|[一二三四五六七八九十]+、|（[一二三四五六七八九十]+）|\\([一二三四五六七八九十]+\\)|第[一二三四五六七八九十]+[，、])"
          }
        },
        {
          "not": {
            "pattern": "\\n\\s*\\n"
          }
        }
      ]
    },
    "paragraphBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "text",
        "styleKey"
      ],
      "properties": {
        "type": {
          "const": "paragraph"
        },
        "text": {
          "$ref": "#/$defs/cleanText"
        },
        "styleKey": {
          "const": "body"
        }
      }
    },
    "listBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "ordered",
        "styleKey",
        "items"
      ],
      "properties": {
        "type": {
          "const": "list"
        },
        "ordered": {
          "type": "boolean"
        },
        "styleKey": {
          "enum": [
            "orderedList",
            "unorderedList"
          ]
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/cleanText"
          }
        }
      },
      "oneOf": [
        {
          "properties": {
            "ordered": {
              "const": true
            },
            "styleKey": {
              "const": "orderedList"
            }
          }
        },
        {
          "properties": {
            "ordered": {
              "const": false
            },
            "styleKey": {
              "const": "unorderedList"
            }
          }
        }
      ]
    },
    "tableBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "styleKey",
        "columns",
        "rows"
      ],
      "properties": {
        "type": {
          "const": "table"
        },
        "styleKey": {
          "const": "standardTable"
        },
        "columns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/cleanText"
          }
        },
        "rows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "headingBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "level",
        "text",
        "styleKey"
      ],
      "properties": {
        "type": {
          "const": "heading"
        },
        "level": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4
        },
        "text": {
          "$ref": "#/$defs/cleanText"
        },
        "styleKey": {
          "enum": [
            "heading1",
            "heading2",
            "heading3",
            "heading4"
          ]
        }
      },
      "oneOf": [
        {
          "properties": {
            "level": {
              "const": 1
            },
            "styleKey": {
              "const": "heading1"
            }
          }
        },
        {
          "properties": {
            "level": {
              "const": 2
            },
            "styleKey": {
              "const": "heading2"
            }
          }
        },
        {
          "properties": {
            "level": {
              "const": 3
            },
            "styleKey": {
              "const": "heading3"
            }
          }
        },
        {
          "properties": {
            "level": {
              "const": 4
            },
            "styleKey": {
              "const": "heading4"
            }
          }
        }
      ]
    }
  }
}
